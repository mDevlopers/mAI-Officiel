+export const ModelSelectorLogo = ({
+  provider,
+  className,
+  ...props
+}: ModelSelectorLogoProps) => {
+  // Mappings for providers to standard icons
+  // using existing logic for Deepseek and new styles
+  const logoProvider = provider === "ollama" ? "meta" : provider === "openrouter" ? "fastrouter" : provider;
+
+  return (
+    <img
+      {...props}
+      alt={`${provider} logo`}
+      className={cn("size-4 dark:invert", className)}
+      height={16}
+      src={`https://models.dev/logos/${logoProvider}.svg`}
+      width={16}
+    />
+  );
+};

 export type ModelSelectorLogoGroupProps = ComponentProps<"div">;
