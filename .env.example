# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Codes d'activation premium (validation serveur uniquement)
MAI_PLUS=****
MAI_PRO=****
MAI_MAX=****

# Providers low-cost texte
CEREBRAS_API_KEY=****
MISTRAL_API_KEY=****
FS_API_KEY=****
HF_API_KEY=****
GEMINI_API_KEY_1=****
GEMINI_API_KEY_2=****
GEMINI_API_KEY_3=****
GEMINI_API_KEY_4=****

# OpenRouter (fallback multi-clés)
OPENROUTER_API_KEY_1=****
OPENROUTER_API_KEY_2=****
OPENROUTER_API_KEY_3=****

# Fireworks AI (OpenAI-compatible)
FIREWORKS_API_KEY=****
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Ollama (local ou self-hosted)
# Laisser OLLAMA_API_TOKEN vide si votre instance n'exige pas d'auth.
OLLAMA_API_TOKEN=
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api

# Optionnel: endpoints custom
# CEREBRAS_API_BASE_URL=https://api.cerebras.ai/v1
# MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
# FS_API_BASE_URL=https://api.francestudent.org/v1
# HUGGINGFACE_API_BASE_URL=https://router.huggingface.co/v1/chat/completions
