# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Codes d'activation premium (validation serveur uniquement)
MAI_PLUS=****
MAI_PRO=****
MAI_MAX=****

# Providers low-cost texte
CEREBRAS_API_KEY=****
MISTRAL_API_KEY=****

# Optionnel: endpoints custom
# CEREBRAS_API_BASE_URL=https://api.cerebras.ai/v1
# MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
